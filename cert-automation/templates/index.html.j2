<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ domain_name }} - HTTPS Enabled</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 50px auto;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .container {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        }
        h1 { color: #fff; }
        .status {
            background: #4CAF50;
            padding: 15px;
            border-radius: 5px;
            margin: 20px 0;
        }
        .info {
            background: rgba(255, 255, 255, 0.2);
            padding: 15px;
            border-radius: 5px;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔒 Welcome to {{ domain_name }}</h1>
        <div class="status">
            <strong>✅ HTTPS is Enabled!</strong>
        </div>
        <div class="info">
            <h2>Server Information</h2>
            <p><strong>Hostname:</strong> {{ domain_name }}</p>
            <p><strong>Web Server:</strong> Apache/RHEL 9</p>
            <p><strong>SSL/TLS:</strong> Let's Encrypt Certificate</p>
            <p><strong>Deployed:</strong> {{ ansible_date_time.iso8601 }}</p>
        </div>
        <div class="info">
            <h2>Certificate Details</h2>
            <p>This site is secured with a Let's Encrypt SSL certificate obtained via ACME protocol with DNS-01 validation.</p>
        </div>
    </div>
</body>
</html>
