body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    max-width: 900px;
    margin: 50px auto;
    padding: 20px;
    background: linear-gradient(135deg, #0078d4 0%, #00bcf2 100%);
    color: white;
}
.container {
    background: rgba(255, 255, 255, 0.1);
    padding: 40px;
    border-radius: 10px;
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    backdrop-filter: blur(4px);
}
h1 {
    color: #fff;
    border-bottom: 3px solid #00bcf2;
    padding-bottom: 15px;
}
.status {
    background: #107c10;
    padding: 20px;
    border-radius: 5px;
    margin: 20px 0;
    text-align: center;
    font-size: 1.2em;
}
.info {
    background: rgba(255, 255, 255, 0.2);
    padding: 20px;
    border-radius: 5px;
    margin: 15px 0;
}
.info h2 {
    margin-top: 0;
    color: #00bcf2;
}
.info p {
    margin: 10px 0;
}
.footer {
    margin-top: 30px;
    text-align: center;
    opacity: 0.8;
    font-size: 0.9em;
}
